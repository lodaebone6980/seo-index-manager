{
  "manifest_version": 3,
  "name": "SEO Index Manager",
  "version": "1.2.0",
  "description": "Auto submit URLs to Naver, Daum, Google, Bing webmaster tools",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "notifications",
    "sidePanel"
  ],
  "host_permissions": [
    "https://searchadvisor.naver.com/*",
    "https://webmaster.daum.net/*",
    "https://search.google.com/*",
    "https://www.bing.com/webmasters/*",
    "http://localhost:*/*",
    "https://*.up.railway.app/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://searchadvisor.naver.com/*",
        "https://webmaster.daum.net/*"
      ],
      "js": [
        "content-scripts/webmaster-automation.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}